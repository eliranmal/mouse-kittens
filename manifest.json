{
  "name": "cat 'n mouse",
  "version": "1.1",
  "manifest_version": 3,
  "description": "changes your cursor to a cat",
  "action": {
    "default_title": "cat 'n mouse",
    "default_popup": "popup.html"
  },
  "commands": {
    "toggle-cursor": {
      "suggested_key": {
        "default": "Alt+Shift+A"
      },
      "description": "toggle cursor"
    }
  },
  "background": {
    "service_worker": "service-worker.js",
    "scripts": ["service-worker.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "css": ["style.css"],
      "js": ["content.js"]
    }
  ],
  "permissions": [
    "activeTab",
    "storage"
  ]
}
